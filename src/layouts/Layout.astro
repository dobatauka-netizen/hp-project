---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';

interface Props {
  title: string;
  description?: string;
  ogpImage?: string;
}

const { title, description, ogpImage } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <SEOHead title={title} description={description} ogpImage={ogpImage} />
  </head>
  <body class="min-h-screen flex flex-col">
    <slot />
  </body>
</html>
