---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CTAButton from '../components/CTAButton.astro';
import CTASection from '../components/CTASection.astro';
import { SITE, SERVICE_PAGE } from '../config/site';

const { heading, subheading, services } = SERVICE_PAGE;
---

<BaseLayout title={`${heading} | ${SITE.name}`} description={`${SITE.name}のサービス一覧です。`}>

  <PageHeader title={heading} subtitle={subheading} />

  <!-- サービス一覧 -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto space-y-16">
      {services.map((service, i) => (
        <div class={`grid grid-cols-1 md:grid-cols-2 gap-12 items-center ${i % 2 === 1 ? 'md:[direction:rtl]' : ''}`}>
          <div class="bg-gray-100 rounded-2xl aspect-video md:[direction:ltr]"></div>
          <div class="md:[direction:ltr]">
            <h2 class="text-2xl font-bold text-gray-900 mb-4">{service.title}</h2>
            <p class="text-gray-600 leading-relaxed mb-6">{service.description}</p>
            <ul class="space-y-2 mb-8">
              {service.features.map((f) => (
                <li class="flex items-center gap-2 text-gray-700">
                  <span class="w-2 h-2 bg-blue-600 rounded-full shrink-0"></span>
                  {f}
                </li>
              ))}
            </ul>
            <CTAButton label="詳しく相談する" href="/contact" />
          </div>
        </div>
      ))}
    </div>
  </section>

  <CTASection
    title="ご不明な点はお気軽に"
    subtitle="サービスについてのご質問・ご相談を受け付けています。"
    label="お問い合わせ"
  />

</BaseLayout>
