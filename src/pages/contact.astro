---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';

const formAction = `https://formspree.io/f/${SITE.formspreeId}`;
---

<BaseLayout title={`お問い合わせ | ${SITE.name}`} description={`${SITE.name}へのお問い合わせはこちらから。`}>

  <!-- ページヘッダー -->
  <section class="bg-gray-900 text-white py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl font-bold mb-4">お問い合わせ</h1>
      <p class="text-gray-400 text-lg">ご質問・ご相談はお気軽にどうぞ。</p>
    </div>
  </section>

  <!-- フォーム -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-2xl mx-auto">

      <!-- 送信前フォーム -->
      <div id="form-area">
        <p class="text-gray-600 text-center mb-10">
          下記フォームよりお問い合わせください。<br />
          {SITE.contact.hours}にご返信いたします。
        </p>
        <form id="contact-form" action={formAction} method="POST" class="space-y-6">
          <div>
            <label for="name" class="block text-sm font-semibold text-gray-700 mb-2">
              お名前 <span class="text-red-500">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
              placeholder="山田 太郎"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-2">
              メールアドレス <span class="text-red-500">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
              placeholder="example@email.com"
            />
          </div>

          <div>
            <label for="company" class="block text-sm font-semibold text-gray-700 mb-2">
              会社名
            </label>
            <input
              type="text"
              id="company"
              name="company"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
              placeholder="株式会社〇〇"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-gray-700 mb-2">
              お問い合わせ内容 <span class="text-red-500">*</span>
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows={6}
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none"
              placeholder="お問い合わせ内容をご記入ください。"
            ></textarea>
          </div>

          <!-- Formspree スパム対策 -->
          <input type="text" name="_gotcha" class="hidden" />

          <button
            type="submit"
            id="submit-btn"
            class="w-full py-4 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-700 transition-colors text-lg disabled:opacity-50"
          >
            送信する
          </button>
        </form>
      </div>

      <!-- 送信完了メッセージ -->
      <div id="success-area" class="hidden text-center py-16">
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">送信が完了しました</h2>
        <p class="text-gray-600">お問い合わせありがとうございます。<br />確認次第、担当者よりご連絡いたします。</p>
        <a href="/" class="inline-block mt-8 text-blue-600 hover:underline">トップページへ戻る</a>
      </div>

    </div>
  </section>

</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const formArea = document.getElementById('form-area');
  const successArea = document.getElementById('success-area');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = '送信中...';

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        formArea?.classList.add('hidden');
        successArea?.classList.remove('hidden');
      } else {
        alert('送信に失敗しました。時間をおいて再度お試しください。');
        submitBtn.disabled = false;
        submitBtn.textContent = '送信する';
      }
    } catch {
      alert('通信エラーが発生しました。');
      submitBtn.disabled = false;
      submitBtn.textContent = '送信する';
    }
  });
</script>
