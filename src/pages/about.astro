---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import { SITE, ABOUT_PAGE } from '../config/site';

const { mission, message, companyInfo } = ABOUT_PAGE;
---

<BaseLayout title={`会社概要 | ${SITE.name}`} description={`${SITE.name}の会社概要・理念をご紹介します。`}>

  <!-- ページヘッダー -->
  <section class="bg-gray-900 text-white py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl font-bold mb-4">会社概要</h1>
      <p class="text-gray-400 text-lg">私たちについてご紹介します。</p>
    </div>
  </section>

  <!-- ミッション -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">私たちのミッション</h2>
      <p class="text-xl text-gray-600 leading-relaxed">{mission}</p>
    </div>
  </section>

  <!-- 代表メッセージ -->
  <section class="py-20 px-4 bg-blue-50">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">代表メッセージ</h2>
      <div class="bg-white rounded-2xl p-8 shadow-sm">
        <div class="flex gap-6 items-start">
          <div class="w-20 h-20 bg-gray-200 rounded-full shrink-0"></div>
          <div>
            <p class="text-gray-700 leading-relaxed whitespace-pre-line">{message}</p>
            <p class="mt-6 text-sm text-gray-500">代表取締役　氏名</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 会社情報 -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">会社情報</h2>
      <table class="w-full text-left">
        <tbody class="divide-y divide-gray-200">
          {companyInfo.map(({ label, value }) => (
            <tr>
              <th class="py-4 pr-8 text-sm font-semibold text-gray-500 w-1/3 align-top">{label}</th>
              <td class="py-4 text-gray-900">{value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4 bg-blue-600 text-white text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold mb-4">ご相談・お問い合わせ</h2>
      <p class="text-blue-100 mb-8">採用・事業提携のご相談もお気軽にどうぞ。</p>
      <CTAButton label="お問い合わせ" href="/contact" variant="secondary" />
    </div>
  </section>

</BaseLayout>
