---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';
---

<BaseLayout title="会社概要 | Company Name" description="Company Nameの会社概要・理念・メンバーをご紹介します。">
  <!-- ページヘッダー -->
  <section class="bg-gray-900 text-white py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl font-bold mb-4">会社概要</h1>
      <p class="text-gray-400 text-lg">私たちについてご紹介します。</p>
    </div>
  </section>

  <!-- 理念 -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">私たちのミッション</h2>
      <p class="text-xl text-gray-600 leading-relaxed">
        お客様のビジネス成長を全力でサポートし、<br />
        地域社会に貢献し続けることが私たちの使命です。
      </p>
    </div>
  </section>

  <!-- 会社情報テーブル -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">会社情報</h2>
      <table class="w-full text-left">
        <tbody class="divide-y divide-gray-200">
          {[
            ['会社名', 'Company Name 株式会社'],
            ['設立', '2020年4月'],
            ['代表者', '代表取締役 氏名'],
            ['所在地', '〒000-0000 東京都○○区○○1-2-3'],
            ['電話番号', '000-0000-0000'],
            ['メール', 'info@example.com'],
            ['事業内容', 'サービス01、サービス02、サービス03'],
          ].map(([label, value]) => (
            <tr>
              <th class="py-4 pr-8 text-sm font-semibold text-gray-500 w-1/3">{label}</th>
              <td class="py-4 text-gray-900">{value}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4 bg-blue-600 text-white text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold mb-4">一緒に働きませんか？</h2>
      <p class="text-blue-100 mb-8">採用・事業提携のご相談もお気軽にどうぞ。</p>
      <CTAButton label="お問い合わせ" href="/contact" variant="secondary" />
    </div>
  </section>
</BaseLayout>
