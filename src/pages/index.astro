---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CTAButton from '../components/CTAButton.astro';
import { SITE, HOME_PAGE } from '../config/site';

const { hero, features, reasons, cta } = HOME_PAGE;
---

<BaseLayout title={`ホーム | ${SITE.name}`} description={SITE.description}>

  <Hero
    title={hero.title}
    subtitle={hero.subtitle}
    ctaLabel={hero.ctaLabel}
    ctaHref={hero.ctaHref}
  />

  <!-- 特徴・強み -->
  <section class="py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-4">サービスの特徴</h2>
      <p class="text-center text-gray-600 mb-12">お客様のニーズに合わせた幅広いサービスをご提供しています。</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {features.map((item) => (
          <div class="p-8 bg-gray-50 rounded-xl hover:shadow-md transition-shadow">
            <div class="w-12 h-12 bg-blue-100 rounded-lg mb-4"></div>
            <h3 class="text-xl font-bold text-gray-900 mb-3">{item.title}</h3>
            <p class="text-gray-600 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-12">
        <CTAButton label="サービス一覧を見る" href="/service" variant="secondary" />
      </div>
    </div>
  </section>

  <!-- 選ばれる理由 -->
  <section class="py-20 px-4 bg-blue-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">選ばれる理由</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {reasons.map((item) => (
          <div class="flex gap-4 p-6 bg-white rounded-xl">
            <span class="text-3xl font-bold text-blue-200 shrink-0">{item.num}</span>
            <div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{item.title}</h3>
              <p class="text-gray-600">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-4 bg-blue-600 text-white text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold mb-4">{cta.title}</h2>
      <p class="text-blue-100 mb-8">{cta.subtitle}</p>
      <CTAButton label={cta.label} href="/contact" variant="secondary" />
    </div>
  </section>

</BaseLayout>
