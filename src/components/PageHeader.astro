---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<section class="bg-gray-900 text-white py-20 px-4">
  <div class="max-w-4xl mx-auto text-center">
    <h1 class="text-4xl font-bold mb-4">{title}</h1>
    <p class="text-gray-400 text-lg">{subtitle}</p>
  </div>
</section>
