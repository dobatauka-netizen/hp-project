---
import { ASSISTANT_CONFIG } from '../config/site';

const { enabled, buttonLabel, headerTitle, headerSubtitle, placeholderText, welcomeMessage } = ASSISTANT_CONFIG;
---

{enabled && (
  <div id="assistant-root">
    <!-- フローティングボタン -->
    <button
      id="assistant-toggle"
      aria-label={buttonLabel}
      class="fixed bottom-6 right-6 z-50 flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white rounded-full shadow-lg px-4 py-3 transition-all duration-200 hover:scale-105 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:ring-offset-2"
    >
      <!-- チャットアイコン -->
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
      </svg>
      <span class="text-sm font-medium" id="assistant-btn-label">{buttonLabel}</span>
    </button>

    <!-- チャットウィジェット -->
    <div
      id="assistant-widget"
      class="fixed bottom-24 right-6 z-50 w-80 sm:w-96 bg-white rounded-2xl shadow-2xl border border-gray-100 flex flex-col overflow-hidden transition-all duration-300 opacity-0 scale-95 pointer-events-none"
      style="max-height: 520px;"
      aria-hidden="true"
    >
      <!-- ヘッダー -->
      <div class="bg-blue-600 px-4 py-3 flex items-center justify-between shrink-0">
        <div>
          <p class="text-white font-semibold text-sm leading-tight">{headerTitle}</p>
          <p class="text-blue-200 text-xs leading-tight mt-0.5">{headerSubtitle}</p>
        </div>
        <button
          id="assistant-close"
          aria-label="閉じる"
          class="text-blue-200 hover:text-white transition-colors focus:outline-none"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- メッセージエリア -->
      <div id="assistant-messages" class="flex-1 overflow-y-auto p-4 space-y-3 bg-gray-50" style="min-height: 280px;">
        <!-- ウェルカムメッセージ -->
        <div class="flex gap-2">
          <div class="w-7 h-7 rounded-full bg-blue-600 flex items-center justify-center shrink-0 mt-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714a2.25 2.25 0 001.659 1.591L19 14.5m-9.25 0a2.25 2.25 0 000 3.182m0-3.182l-4.5 4.5" />
            </svg>
          </div>
          <div class="bg-white rounded-2xl rounded-tl-sm px-3 py-2 text-sm text-gray-700 shadow-sm max-w-[85%]">
            {welcomeMessage}
          </div>
        </div>
      </div>

      <!-- 入力エリア -->
      <div class="border-t border-gray-100 p-3 bg-white shrink-0">
        <form id="assistant-form" class="flex gap-2">
          <input
            id="assistant-input"
            type="text"
            placeholder={placeholderText}
            autocomplete="off"
            class="flex-1 text-sm border border-gray-200 rounded-full px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent placeholder-gray-400"
          />
          <button
            type="submit"
            id="assistant-send"
            aria-label="送信"
            class="bg-blue-600 hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed text-white rounded-full p-2 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-400"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>
)}

<script>
  const toggle = document.getElementById('assistant-toggle');
  const widget = document.getElementById('assistant-widget');
  const closeBtn = document.getElementById('assistant-close');
  const form = document.getElementById('assistant-form') as HTMLFormElement | null;
  const input = document.getElementById('assistant-input') as HTMLInputElement | null;
  const sendBtn = document.getElementById('assistant-send') as HTMLButtonElement | null;
  const messagesEl = document.getElementById('assistant-messages');

  if (!toggle || !widget || !closeBtn || !form || !input || !sendBtn || !messagesEl) {
    // アシスタントが無効の場合はスキップ
  } else {
    let isOpen = false;
    let isLoading = false;
    // role: 'user' | 'assistant'
    const history: { role: 'user' | 'assistant'; content: string }[] = [];

    function openWidget() {
      isOpen = true;
      widget.classList.remove('opacity-0', 'scale-95', 'pointer-events-none');
      widget.classList.add('opacity-100', 'scale-100');
      widget.setAttribute('aria-hidden', 'false');
      input.focus();
    }

    function closeWidget() {
      isOpen = false;
      widget.classList.add('opacity-0', 'scale-95', 'pointer-events-none');
      widget.classList.remove('opacity-100', 'scale-100');
      widget.setAttribute('aria-hidden', 'true');
    }

    toggle.addEventListener('click', () => {
      isOpen ? closeWidget() : openWidget();
    });
    closeBtn.addEventListener('click', closeWidget);

    function appendMessage(role: 'user' | 'assistant', text: string) {
      const wrapper = document.createElement('div');
      wrapper.className = role === 'user'
        ? 'flex gap-2 justify-end'
        : 'flex gap-2';

      if (role === 'assistant') {
        const avatar = document.createElement('div');
        avatar.className = 'w-7 h-7 rounded-full bg-blue-600 flex items-center justify-center shrink-0 mt-0.5';
        avatar.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714a2.25 2.25 0 001.659 1.591L19 14.5m-9.25 0a2.25 2.25 0 000 3.182m0-3.182l-4.5 4.5" /></svg>`;
        wrapper.appendChild(avatar);
      }

      const bubble = document.createElement('div');
      bubble.className = role === 'user'
        ? 'bg-blue-600 text-white rounded-2xl rounded-tr-sm px-3 py-2 text-sm max-w-[85%] whitespace-pre-wrap'
        : 'bg-white rounded-2xl rounded-tl-sm px-3 py-2 text-sm text-gray-700 shadow-sm max-w-[85%] whitespace-pre-wrap';
      bubble.textContent = text;
      wrapper.appendChild(bubble);

      messagesEl.appendChild(wrapper);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      return bubble;
    }

    function appendTypingIndicator() {
      const wrapper = document.createElement('div');
      wrapper.className = 'flex gap-2';
      wrapper.id = 'typing-indicator';

      const avatar = document.createElement('div');
      avatar.className = 'w-7 h-7 rounded-full bg-blue-600 flex items-center justify-center shrink-0 mt-0.5';
      avatar.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714a2.25 2.25 0 001.659 1.591L19 14.5m-9.25 0a2.25 2.25 0 000 3.182m0-3.182l-4.5 4.5" /></svg>`;

      const bubble = document.createElement('div');
      bubble.className = 'bg-white rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm flex gap-1 items-center';
      bubble.innerHTML = `
        <span class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce" style="animation-delay:0ms"></span>
        <span class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce" style="animation-delay:150ms"></span>
        <span class="w-1.5 h-1.5 bg-gray-400 rounded-full animate-bounce" style="animation-delay:300ms"></span>
      `;

      wrapper.appendChild(avatar);
      wrapper.appendChild(bubble);
      messagesEl.appendChild(wrapper);
      messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function removeTypingIndicator() {
      document.getElementById('typing-indicator')?.remove();
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text || isLoading) return;

      input.value = '';
      isLoading = true;
      sendBtn.disabled = true;

      appendMessage('user', text);
      history.push({ role: 'user', content: text });
      appendTypingIndicator();

      try {
        const res = await fetch('/api/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ messages: history }),
        });
        const data = await res.json();
        removeTypingIndicator();

        const reply: string = data.reply || data.error || 'エラーが発生しました。';
        appendMessage('assistant', reply);
        history.push({ role: 'assistant', content: reply });
      } catch {
        removeTypingIndicator();
        const errorMsg = 'ネットワークエラーが発生しました。しばらくしてからお試しください。';
        appendMessage('assistant', errorMsg);
      } finally {
        isLoading = false;
        sendBtn.disabled = false;
        input.focus();
      }
    });
  }
</script>
