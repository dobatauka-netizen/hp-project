rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // お知らせ：公開記事は誰でも読める・書き込みはログイン管理者のみ
    match /news/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // 管理者情報：ログイン済みのみ読み書き可
    match /admins/{doc} {
      allow read, write: if request.auth != null;
    }
    // ページ画像：誰でも読める・書き込みはログイン管理者のみ
    match /site-images/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // ページテキスト：誰でも読める・書き込みはログイン管理者のみ
    match /site-content/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // お問い合わせ：誰でも書き込み可・読み取りはログイン管理者のみ
    match /contacts/{doc} {
      allow read: if request.auth != null;
      allow write: if true;
    }
  }
}
